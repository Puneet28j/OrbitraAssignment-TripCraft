# ══════════════════════════════════════════════════════
# TripCraft Server — Environment Variables
# Copy this file to .env and fill in all values
# ══════════════════════════════════════════════════════

# ── Server ───────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── MongoDB ──────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/tripcraft

# ── JWT Secrets (min 32 chars each) ──────────────────
JWT_ACCESS_SECRET=your-access-secret-at-least-32-characters-long
JWT_REFRESH_SECRET=your-refresh-secret-at-least-32-characters-long
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── Cloudinary ───────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── OpenRouter AI ────────────────────────────────────
# Get a free key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key
# Optional — default chain: deepseek-v4-flash:free → gemma-4-31b:free → nemotron-3-super:free
# OPENROUTER_MODEL=deepseek/deepseek-v4-flash:free
# OPENROUTER_MAX_OUTPUT_TOKENS=4200
# OPENROUTER_MAX_MODELS=1
# EXTRACTION_CONCURRENCY=3
# EXTRACTION_MODE=fast
# EXTRACTION_MODE=robust

# ── Client URL (for CORS) ───────────────────────────
CLIENT_URL=http://localhost:5173
